<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_horizontal">

    <!-- Logo for Portrait Mode -->
    <ImageView
        android:id="@+id/iv_logo"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/contact_icon"
        android:scaleType="fitCenter"
        android:layout_marginBottom="16dp" />

    <!-- First Name -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/first_name"
        android:textSize="14sp"
        android:layout_marginTop="8dp" />
    <EditText
        android:id="@+id/et_first_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textPersonName"
        android:hint="@string/first_name_hint" />

    <!-- Last Name -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/last_name"
        android:textSize="14sp"
        android:layout_marginTop="8dp" />
    <EditText
        android:id="@+id/et_last_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="textPersonName"
        android:hint="@string/last_name_hint" />

    <!-- Birthday -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/birthday"
        android:textSize="14sp"
        android:layout_marginTop="8dp" />
    <EditText
        android:id="@+id/et_birthday"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="date"
        android:hint="@string/birthday_hint" />

    <!-- Phone Number -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/phone_number"
        android:textSize="14sp"
        android:layout_marginTop="8dp" />
    <EditText
        android:id="@+id/et_phone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="phone"
        android:hint="@string/phone_number_hint" />

    <!-- Random Number Label -->
    <TextView
        android:id="@+id/tv_random_number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/random_number_label"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:gravity="center" />

    <!-- Last Random Number Label (hidden initially) -->
    <TextView
        android:id="@+id/tv_last_random_number"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/last_random_number_label"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:visibility="gone" />

</LinearLayout>
